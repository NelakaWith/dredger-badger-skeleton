# Database Configuration
# Neon Postgres URL. Must support pgvector.
DATABASE_URL="postgres://user:pass@host/dbname"

# Redis Configuration (for BullMQ)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# AI Provider Configuration
# Choose between 'groq' or 'gemini' for the primary intelligence extraction.
AI_PROVIDER="groq"

# Groq API Keys (Required if AI_PROVIDER=groq)
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

# Google Gemini API Keys (Required for Embeddings and optional for extraction)
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash-lite"
GEMINI_EMBEDDING_MODEL="gemini-embedding-2-preview"

# External Crawler API (Optional)
# If using the external crawl4ai python service
CRAWLER_URL="http://127.0.0.1:8000"
